# Copy this file to .env and fill in the values. .env is gitignored.

# Root URL of the application under test (used by the base page open() helper). Required.
BASE_URL=https://www.saucedemo.com

# Browser name used to build WDIO capabilities in wdio.conf.ts. Optional (default: chrome).
BROWSER=chrome

# Set to 'true' to append the --headless=new arg to the Chrome capabilities. Optional.
HEADLESS=false

# Standard test account — injected into test data. Required.
TEST_USER_USERNAME=standard_user
TEST_USER_PASSWORD=secret_sauce
