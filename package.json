{
  "name": "qacodes-webdriverio-typescript",
  "version": "1.0.0",
  "description": "Production-style WebdriverIO + TypeScript E2E suite against Sauce Demo — POM, services, parallel sessions, Allure reporting.",
  "type": "module",
  "license": "MIT",
  "author": "qa.codes",
  "homepage": "https://qa.codes/practice/project-samples/webdriverio-typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/qacodes-dev/qacodes-webdriverio-typescript.git"
  },
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:smoke": "wdio run wdio.conf.ts --suite smoke",
    "test:regression": "wdio run wdio.conf.ts --suite regression",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@wdio/allure-reporter": "^9.30.0",
    "@wdio/cli": "^9.30.0",
    "@wdio/globals": "^9.4.5",
    "@wdio/local-runner": "^9.30.0",
    "@wdio/mocha-framework": "^9.30.0",
    "@wdio/spec-reporter": "^9.4.5",
    "allure-commandline": "^2.32.0",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "webdriverio": "^9.4.5"
  }
}
